# ==============================
# 应用信息
# ==============================
APP_NAME=love-girl
APP_ENV=dev

# ==============================
# HTTP 服务
# ==============================
SERVER_ADDR=:8182
SERVER_MODE=debug
# SERVER_INTERNAL_URL=http://gin:8182  # 内网地址，ImageProxy 访问 Gin 用（可选）

# ==============================
# 日志配置
# ==============================
LOG_LEVEL=debug

# ==============================
# 数据库配置
# ==============================
DATASOURCE_DATABASE_DRIVER=sqlite
DATASOURCE_DATABASE_DSN=file:./data/love-girl.db?_fk=1

# ==============================
# JWT 配置
# ==============================
JWT_SECRET=love-girl-123456789012345678901234
JWT_ISSUER=love-girl
JWT_EXPIRE=900        # 单位秒 (15分钟)

# ==============================
# 存储配置
# ==============================
STORAGE_BACKEND=local

# ------------------------------
# Local 存储
# ------------------------------
STORAGE_LOCAL_ROOT=./data/uploads

# ------------------------------
# S3 存储（backend=s3 时使用）
# ------------------------------
# STORAGE_S3_USE_SSL=true
# STORAGE_S3_ENDPOINT=s3.example.com
# STORAGE_S3_REGION=us-east-1
# STORAGE_S3_BUCKET=mybucket
# STORAGE_S3_PUBLIC_URL=https://cdn.example.com  # 公开访问地址（可选）
# STORAGE_S3_CREDENTIALS_ACCESS_KEY_ID=AKIAxxxxxxx
# STORAGE_S3_CREDENTIALS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxx

# ------------------------------
# WebDAV 存储（backend=webdav 时使用）
# ------------------------------
# STORAGE_WEBDAV_ENDPOINT=https://webdav.example.com
# STORAGE_WEBDAV_BASE_PATH=/uploads
# STORAGE_WEBDAV_PUBLIC_URL=https://cdn.example.com  # 公开访问地址（可选）
# STORAGE_WEBDAV_AUTH_USERNAME=admin
# STORAGE_WEBDAV_AUTH_PASSWORD=123456

# ==============================
# 图片代理（imgproxy / thumbor）
# ==============================
# IMAGE_PROXY_INTERNAL_URL=http://imgproxy:8080  # 内网地址，Gin 转发缩略图用
# IMAGE_PROXY_PUBLIC_URL=https://img.example.com  # 公开地址，前端直接访问（可选）