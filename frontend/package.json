{
  "name": "love-girl-monorepo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:frontend": "pnpm --filter web-frontend dev",
    "dev:admin": "pnpm --filter web-admin dev",
    "dev:client": "pnpm --filter client dev",
    "build:frontend": "pnpm --filter web-frontend build",
    "build:admin": "pnpm --filter web-admin build",
    "build:client": "pnpm --filter client build:desktop",
    "build:all": "pnpm -r build",
    "lint": "pnpm -r lint",
    "type-check": "pnpm -r type-check"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}