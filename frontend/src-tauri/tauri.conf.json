{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "LoveGirl",
  "version": "1.0.0",
  "identifier": "com.lovegirl.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build:desktop"
  },
  "app": {
    "windows": [
      {
        "title": "LoveGirl",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "LoveGirl Team",
    "shortDescription": "A romantic app for couples",
    "longDescription": "LoveGirl is a romantic application for couples to record their beautiful moments together.",
    "category": "Lifestyle",
    "windows": {
      "wix": {
        "language": "zh-CN"
      }
    },
    "android": {
      "minSdkVersion": 24
    }
  },
  "plugins": {
    "opener": {}
  }
}
