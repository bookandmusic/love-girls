{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node-terminal",
            "name": "frontend",
            "request": "launch",
            "command": "pnpm run dev --host=0.0.0.0",
            "cwd": "${workspaceFolder}/frontend/web-frontend",
            "env": {
                "VITE_ENV": "dev",
                "VITE_TARGET_SERVER": "http://127.0.0.1:8181"
            }
        },
        {
            "type": "node-terminal",
            "name": "admin",
            "request": "launch",
            "command": "pnpm run dev --host=0.0.0.0",
            "cwd": "${workspaceFolder}/frontend/web-admin",
            "env": {
                "VITE_ENV": "dev",
                "VITE_TARGET_SERVER": "http://127.0.0.1:8181"
            }
        },
        {
            "type": "node-terminal",
            "name": "client",
            "request": "launch",
            "command": "pnpm run dev --host=0.0.0.0",
            "cwd": "${workspaceFolder}/frontend/client",
            "env": {
                "VITE_ENV": "dev",
                "VITE_TARGET_SERVER": "http://127.0.0.1:8181"
            }
        },
        {
            "type": "node-terminal",
            "name": "client:desktop",
            "request": "launch",
            "command": "pnpm run tauri:dev",
            "cwd": "${workspaceFolder}/frontend/client"
        },
        {
            "command": "imageproxy -cache memory:200:4h -cache /tmp/imageproxy -addr :6060 -passRequestHeaders \"Authorization\"",
            "name": "imageproxy",
            "request": "launch",
            "type": "node-terminal"
        },
        {
            "name": "server",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/backend/main.go",
            "cwd": "${workspaceFolder}",
            "env": {
                "SERVER_ADDR": ":8181"
            }
        }
    ]
}